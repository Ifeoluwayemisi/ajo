# Database
DATABASE_URL=postgresql://user:password@localhost:5432/vortx

# JWT
SECRET_KEY=your-secret-key-change-in-prod
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# OpenAI
OPENAI_API_KEY=sk-your-api-key-here

# Interswitch
INTERSWITCH_CLIENT_ID=your-client-id
INTERSWITCH_SECRET_KEY=your-secret-key
INTERSWITCH_BASE_URL=https://webpayapi.interswitch.com/pms/api/v1

# Server
APP_NAME=Vortx API
APP_VERSION=0.1.0

# WhatsApp Bot (Meta Graph API)
WHATSAPP_API_TOKEN=your-meta-whatsapp-token
WHATSAPP_PHONE_ID=your-whatsapp-phone-number-id
WHATSAPP_VERIFY_TOKEN=your-random-verification-token
