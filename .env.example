
# CORE APPLICATION 
APP_NAME=Vortx
DEBUG=False
ENVIRONMENT=production

#  SECRETS (CHANGE THESE!) 
SECRET_KEY=change-this-to-a-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

#  DATABASE 
# PostgreSQL connection string
DATABASE_URL=postgresql://username:password@localhost:5432/vortx_db

#  OPENAI / AI BRAIN 
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
AI_MODEL=gpt-4o

#  INTERSWITCH INTEGRATION 
# Get these from Interswitch after registration
INTERSWITCH_CLIENT_ID=YOUR_CLIENT_ID
INTERSWITCH_SECRET_KEY=YOUR_SECRET_KEY
INTERSWITCH_API_BASE=https://sandbox.interswitchng.com

# Merchant Details (from Interswitch)
INTERSWITCH_TERMINAL_ID=your_terminal_id
INTERSWITCH_MERCHANT_CODE=your_merchant_code
INTERSWITCH_PAY_ITEM_ID=your_pay_item_id

#  FINTECH REVENUE CONFIGURATION 
INSURANCE_SAFETY_FEE=0.015              # 1.5% to insurance pool
TRANSACTION_FEE_RATE=0.02               # 2% transaction fee
NANO_LOAN_INTEREST_RATE=0.08            # 8% for 48-hour loans
SWAP_COMMISSION_RATE=0.5                # 50% of swap fees
ESCROW_INTEREST_RATE=0.05               # 5% annual escrow interest

#  BUSINESS LOGIC SETTINGS 
RETRY_INTERVAL_HOURS=4                  # Retry failed debits every 4h
MAX_RETRY_ATTEMPTS=5                    # Give up after 5 retries
NANO_LOAN_OFFER_HOURS=48                # Offer loan 48h before due
NANO_LOAN_TERM_DEFAULT=7                # 7-day repayment term
HIGH_VALUE_THRESHOLD=100000             # CEO approval needed for >= this
DEADMAN_SWITCH_HOURS=24                 # Admin override if CEO inactive

#  CEO / MASTER OVERRIDE 
MASTER_CEO_PIN=1234

#  WHATSAPP BOT 
WHATSAPP_API_TOKEN=YOUR_WHATSAPP_TOKEN
WHATSAPP_PHONE_ID=YOUR_PHONE_ID

#  FRONTEND 
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=Vortx


