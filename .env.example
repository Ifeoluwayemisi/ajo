# Copy this file to hackathon/vortx/.env
# This repo-root .env file is the only env file loaded by the backend.

# CORE APPLICATION
APP_NAME=Vortx
DEBUG=False
ENVIRONMENT=development

# SECRETS
SECRET_KEY=change-this-to-a-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ENCRYPTION_KEY=replace-with-a-generated-fernet-key

# DATABASE
DATABASE_URL=sqlite:///./vortx.db

# OPENAI / AI BRAIN
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
AI_MODEL=gpt-4o

# INTERSWITCH INTEGRATION
INTERSWITCH_ENV=sandbox

INTERSWITCH_CLIENT_ID_SANDBOX=your_sandbox_client_id
INTERSWITCH_SECRET_KEY_SANDBOX=your_sandbox_secret_key
INTERSWITCH_API_BASE_SANDBOX=https://sandbox.interswitchng.com

INTERSWITCH_CLIENT_ID_PROD=your_production_client_id
INTERSWITCH_SECRET_KEY_PROD=your_production_secret_key
INTERSWITCH_API_BASE_PROD=https://api.interswitchng.com

INTERSWITCH_TERMINAL_ID=your_terminal_id
INTERSWITCH_MERCHANT_CODE=your_merchant_code
INTERSWITCH_PAY_ITEM_ID=your_pay_item_id

# FINTECH REVENUE CONFIGURATION
INSURANCE_SAFETY_FEE=0.015
TRANSACTION_FEE_RATE=0.02
NANO_LOAN_INTEREST_RATE=0.08
SWAP_COMMISSION_RATE=0.5
ESCROW_INTEREST_RATE=0.05

# BUSINESS LOGIC SETTINGS
RETRY_INTERVAL_HOURS=4
MAX_RETRY_ATTEMPTS=5
NANO_LOAN_OFFER_HOURS=48
NANO_LOAN_TERM_DEFAULT=7
HIGH_VALUE_THRESHOLD=100000
DEADMAN_SWITCH_HOURS=24

# CEO / MASTER OVERRIDE
MASTER_CEO_PIN=1234

# WHATSAPP BOT
WHATSAPP_API_TOKEN=your_whatsapp_token
WHATSAPP_PHONE_ID=your_whatsapp_phone_id
WHATSAPP_VERIFY_TOKEN=your_whatsapp_verify_token

# FRONTEND
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=Vortx
